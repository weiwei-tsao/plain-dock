{
  "name": "plaindock",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "docker:sync-from-turso": "node scripts/sync-turso-to-docker.mjs",
    "test:sync": "node --test scripts/sync-turso-to-docker.test.mjs",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "remotedev": "next dev --turbopack -p 3000 --hostname 0.0.0.0"
  },
  "dependencies": {
    "@prisma/adapter-libsql": "6.19.2",
    "@prisma/client": "^6.19.2",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.564.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@next/eslint-plugin-next": "^15.5.12",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/react": "19.2.14",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.55.0"
  }
}
